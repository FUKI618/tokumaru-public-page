---
const nagoyaWards = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearbyAreas = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市（三重県）"];
---
<section id="area" class="py-20 md:py-32 bg-sand">
  <div class="max-w-7xl mx-auto px-5">
    <div class="md:flex md:items-end md:justify-between gap-10 mb-10 md:mb-14">
      <div>
        <p class="text-graphite text-xs tracking-[0.32em] mb-4 uppercase">Area</p>
        <h2 class="font-serif text-3xl md:text-5xl font-bold text-ink leading-[1.14]">対応エリア</h2>
      </div>
      <p class="text-graphite-light text-base leading-[1.85] max-w-xl">
        対応地域を文字の羅列ではなく、タグとして認識しやすい形に整理しています。名古屋市内はもちろん、近郊エリアも幅広く対応しています。
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      <div class="rounded-[28px] border border-sand-dark bg-white px-6 py-7">
        <h3 class="text-ink font-bold text-sm tracking-[0.18em] uppercase mb-5">名古屋市全域（16区）</h3>
        <div class="flex flex-wrap gap-2.5">
          {nagoyaWards.map((ward) => <span class="rounded-full border border-sand-dark bg-sand px-4 py-2 text-sm text-graphite">{ward}</span>)}
        </div>
      </div>
      <div class="rounded-[28px] border border-sand-dark bg-white px-6 py-7">
        <h3 class="text-ink font-bold text-sm tracking-[0.18em] uppercase mb-5">近郊エリア</h3>
        <div class="flex flex-wrap gap-2.5">
          {nearbyAreas.map((area) => <span class="rounded-full border border-sand-dark bg-sand px-4 py-2 text-sm text-graphite">{area}</span>)}
        </div>
        <p class="text-graphite-light text-sm mt-5">上記以外の愛知県内エリアもご相談ください。</p>
      </div>
    </div>
  </div>
</section>
