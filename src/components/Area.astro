---
const nagoyaWards = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearbyAreas = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市（三重県）"];
---
<section id="area" class="py-16 md:py-28">
  <div class="max-w-5xl mx-auto px-5">
    <p class="text-gold text-[10px] md:text-xs tracking-[0.15em] font-bold mb-3 uppercase">Service Area</p>
    <h2 class="text-xl md:text-3xl font-bold text-navy mb-8 md:mb-14">
      対応エリア
    </h2>

    <div class="md:flex md:gap-16">
      <div class="mb-8 md:mb-0">
        <h3 class="font-bold text-navy text-sm mb-3">名古屋市全域（16区）</h3>
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-warm-gray-light text-sm">
          {nagoyaWards.map((ward) => <span>{ward}</span>)}
        </div>
      </div>
      <div>
        <h3 class="font-bold text-navy text-sm mb-3">近郊エリア（愛知県・三重県）</h3>
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-warm-gray-light text-sm">
          {nearbyAreas.map((area) => <span>{area}</span>)}
        </div>
        <p class="text-warm-gray-light text-[10px] mt-3">上記以外の愛知県内エリアもご相談ください</p>
      </div>
    </div>
  </div>
</section>
