---
import { privacyPolicyPath, sectionPath, assetPath } from "../lib/site";
const logoUrl = assetPath("logo.png");
---
<footer class="bg-navy-dark text-white/50 py-16 md:py-20">
  <div class="max-w-5xl mx-auto px-5">
    <div class="md:flex md:justify-between md:gap-12 mb-12">
      <div class="mb-8 md:mb-0">
        <div class="flex items-center gap-3 mb-4">
          <img src={logoUrl} alt="徳丸商会ロゴ" width="40" height="40" class="w-10 h-10 object-contain" style="filter: drop-shadow(0 0 1px rgba(255,255,255,0.3));" />
          <div>
            <p class="text-white font-bold text-lg leading-tight">徳丸商会</p>
            <p class="text-[9px] text-white/30 tracking-[0.2em]">TOKUMARU SHOKAI</p>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-1">名古屋市・近郊エリアの出張買取サービス</p>
        <p class="text-xs">古物商許可番号：第541042309800号</p>
      </div>

      <div class="flex gap-12 md:gap-16 text-sm">
        <div>
          <p class="text-white font-bold text-xs tracking-widest uppercase mb-4">Contact</p>
          <p class="mb-1"><a href="tel:052-990-3968" class="hover:text-white transition-colors">052-990-3968</a></p>
          <p class="mb-1">9:00〜21:00（年中無休）</p>
          <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">LINE公式</a>
        </div>
        <div>
          <p class="text-white font-bold text-xs tracking-widest uppercase mb-4">Menu</p>
          <nav class="flex flex-col gap-1.5">
            <a href={sectionPath("service")} class="hover:text-white transition-colors">サービス</a>
            <a href={sectionPath("items")} class="hover:text-white transition-colors">買取品目</a>
            <a href={sectionPath("area")} class="hover:text-white transition-colors">対応エリア</a>
            <a href={sectionPath("faq")} class="hover:text-white transition-colors">よくある質問</a>
            <a href={privacyPolicyPath} class="hover:text-white transition-colors">プライバシーポリシー</a>
          </nav>
        </div>
      </div>
    </div>

    <div class="border-t border-white/8 pt-8 pb-16 md:pb-0 text-center text-xs text-white/25">
      <p>&copy; {new Date().getFullYear()} 徳丸商会 All Rights Reserved.</p>
    </div>
  </div>
</footer>
