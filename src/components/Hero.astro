<section class="bg-navy text-white">
  <div class="max-w-5xl mx-auto px-5 py-14 md:py-28">
    <div class="md:flex md:items-center md:justify-between md:gap-12">
      <!-- 左：テキスト -->
      <div class="md:flex-1 mb-10 md:mb-0">
        <p class="text-gold text-[10px] md:text-xs tracking-[0.2em] font-bold mb-4 uppercase">Nagoya Buying Service</p>
        <h1 class="text-[1.6rem] md:text-[2.8rem] lg:text-5xl font-black leading-[1.3] mb-5">
          名古屋の出張買取なら<br /><span class="text-gold">徳丸商会</span>
        </h1>
        <p class="text-white/65 text-sm md:text-base leading-[1.9] mb-8 max-w-lg">
          中古家電・家具・ブランド品を高価買取。愛知県名古屋市を中心に即日対応。お電話一本で無料出張いたします。
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-line hover:brightness-110 text-white font-bold text-sm px-6 py-3.5 rounded-lg transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
            写真を送って無料査定
          </a>
          <a href="tel:052-990-3968"
            class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 text-white font-bold text-sm px-6 py-3.5 rounded-lg border border-white/15 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            052-990-3968
          </a>
