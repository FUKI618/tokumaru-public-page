        <p class="text-white/35 text-[10px] mt-4 tracking-wide">
          査定だけでもOK ・ しつこい営業なし ・ キャンセル料0円
        </p>
      </div>

      <!-- 右：数字 -->
      <div class="md:flex-shrink-0 md:w-56">
        <div class="grid grid-cols-3 md:grid-cols-1 gap-4 md:gap-8">
          <div class="text-center md:text-right">
            <p class="text-2xl md:text-4xl font-black text-gold leading-none">1,200</p>
            <p class="text-[10px] md:text-xs text-white/40 mt-1">累計買取実績（件）</p>
          </div>
          <div class="text-center md:text-right">
            <p class="text-2xl md:text-4xl font-black text-gold leading-none">98<span class="text-base md:text-lg">%</span></p>
            <p class="text-[10px] md:text-xs text-white/40 mt-1">お客様満足度</p>
          </div>
          <div class="text-center md:text-right">
            <p class="text-2xl md:text-4xl font-black text-gold leading-none">0<span class="text-base md:text-lg">円</span></p>
            <p class="text-[10px] md:text-xs text-white/40 mt-1">出張費・査定費</p>
          </div>
        </div>
      </div>
    </div>

    <!-- USPライン -->
    <div class="mt-10 md:mt-16 pt-8 border-t border-white/8">
      <div class="grid grid-cols-3 gap-4 md:gap-8 text-center">
        <div>
          <p class="text-white font-bold text-sm md:text-base">最短30分</p>
          <p class="text-white/35 text-[10px] md:text-xs mt-0.5">で訪問</p>
        </div>
        <div>
          <p class="text-white font-bold text-sm md:text-base">出張費 0円</p>
          <p class="text-white/35 text-[10px] md:text-xs mt-0.5">見積もり無料</p>
        </div>
        <div>
          <p class="text-white font-bold text-sm md:text-base">現金払い</p>
          <p class="text-white/35 text-[10px] md:text-xs mt-0.5">その場でお支払い</p>
        </div>
      </div>
    </div>
  </div>
</section>
