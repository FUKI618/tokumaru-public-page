---
import { assetPath } from "../lib/site";
const results = [
  { name: "冷蔵庫", detail: "大型 500L以上", price: "39,000", image: assetPath("images/results/refrigerator.jpg") },
  { name: "洗濯機", detail: "ドラム式洗濯乾燥機", price: "24,500", image: assetPath("images/results/washing-machine.jpg") },
  { name: "エアコン", detail: "ルームエアコン 取外込", price: "21,000", image: assetPath("images/results/aircon.jpg") },
  { name: "テレビ", detail: "液晶 55インチ", price: "17,000", image: assetPath("images/results/tv.jpg") },
];
---
<section id="results" class="py-16 md:py-28">
  <div class="max-w-5xl mx-auto px-5">
    <p class="text-gold text-[10px] md:text-xs tracking-[0.15em] font-bold mb-3 uppercase">Track Record</p>
    <h2 class="text-xl md:text-3xl font-bold text-navy mb-8 md:mb-14">
      高額買取実績
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {results.map((item) => (
        <div>
          <div class="aspect-[4/3] overflow-hidden rounded-sm mb-3">
            <img src={item.image} alt={`${item.name}の買取実績写真`} width="400" height="300" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <p class="text-navy font-bold text-sm">{item.name}</p>
          <p class="text-warm-gray-light text-[10px] mb-1">{item.detail}</p>
          <p class="text-cta font-black text-lg">¥{item.price}<span class="text-xs font-normal text-warm-gray-light">〜</span></p>
        </div>
      ))}
    </div>

    <p class="text-warm-gray-light text-[10px] mt-6">
      ※買取相場はお品物の状態・年式・メーカーにより異なります。
    </p>
  </div>
</section>
