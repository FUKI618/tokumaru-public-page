---
import { specializedPages, pagePath, homePath } from "../lib/site";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
---

<!-- Desktop: 右側固定ボックス / Mobile: ページ下部に表示 -->
<aside
  x-data="{ open: false }"
  class="fixed right-0 top-1/2 -translate-y-1/2 z-40 hidden md:block"
>
  <!-- トグルタブ -->
  <button
    x-on:click="open = !open"
    class="absolute right-0 top-1/2 -translate-y-1/2 bg-navy text-white text-xs font-bold px-2 py-6 rounded-l-lg shadow-lg hover:bg-navy-light transition-colors"
    style="writing-mode: vertical-rl;"
    x-bind:class="open && 'rounded-l-none'"
  >
    買取メニュー
  </button>

  <!-- パネル -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="translate-x-full opacity-0"
    x-transition:enter-end="translate-x-0 opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="translate-x-0 opacity-100"
    x-transition:leave-end="translate-x-full opacity-0"
    class="bg-white rounded-l-xl shadow-2xl border border-cream-dark p-4 w-56"
    style="display: none;"
  >
    <p class="text-navy font-bold text-sm mb-3">買取メニュー</p>
    <nav class="flex flex-col gap-1.5">
      <a
        href={homePath}
        class:list={[
          "flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition-colors",
          !currentSlug ? "bg-navy text-white font-bold" : "text-warm-gray hover:bg-cream"
        ]}
      >
        <span>🏪</span>
        <span>総合トップ</span>
      </a>
      {specializedPages.map((page) => (
        <a
          href={pagePath(page.slug)}
          class:list={[
            "flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition-colors",
            currentSlug === page.slug ? "bg-navy text-white font-bold" : "text-warm-gray hover:bg-cream"
          ]}
        >
          <span>{page.emoji}</span>
          <span>{page.shortTitle}</span>
        </a>
      ))}
    </nav>
  </div>
</aside>

<!-- Mobile: 横スクロールタブ -->
<div class="md:hidden bg-white border-b border-cream-dark overflow-x-auto">
  <div class="flex gap-2 px-4 py-2.5 min-w-max">
    <a
      href={homePath}
      class:list={[
        "flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-bold whitespace-nowrap transition-colors",
        !currentSlug ? "bg-navy text-white" : "bg-cream text-warm-gray"
      ]}
    >
      <span>🏪</span>
      <span>総合</span>
    </a>
    {specializedPages.map((page) => (
      <a
        href={pagePath(page.slug)}
        class:list={[
          "flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-bold whitespace-nowrap transition-colors",
          currentSlug === page.slug ? "bg-navy text-white" : "bg-cream text-warm-gray"
        ]}
      >
        <span>{page.emoji}</span>
        <span>{page.shortTitle}</span>
      </a>
    ))}
  </div>
</div>
