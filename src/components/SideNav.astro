---
import { specializedPages, pagePath, homePath } from "../lib/site";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const allPages = [
  { slug: "", shortTitle: "総合トップ", href: homePath },
  ...specializedPages.map((p) => ({ slug: p.slug, shortTitle: p.shortTitle, href: pagePath(p.slug) })),
];
---

<nav class="border-y border-sand-dark bg-white/85 backdrop-blur-sm" aria-label="サービスメニュー">
  <div class="max-w-6xl mx-auto px-5">
    <div class="flex items-center gap-2 py-3 overflow-x-auto scrollbar-hide">
      {allPages.map((page) => (
        <a
          href={page.href}
          class:list={[
            "flex-shrink-0 px-4 py-2.5 rounded-full text-xs md:text-[13px] font-bold transition-all whitespace-nowrap border",
            (page.slug === "" ? !currentSlug : currentSlug === page.slug)
              ? "border-ink bg-ink text-white"
              : "border-sand-dark text-graphite hover:bg-sand hover:text-ink"
          ]}
        >
          {page.shortTitle}
        </a>
      ))}
    </div>
  </div>
</nav>
