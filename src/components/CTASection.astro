---
interface Props {
  id?: string;
  variant?: "mid" | "bottom";
}

const { id = "contact", variant = "mid" } = Astro.props;
---

<section id={id} class="relative overflow-hidden py-20 md:py-28 bg-[linear-gradient(180deg,#171d26_0%,#11161d_100%)] text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(184,146,74,0.12),transparent_28%)]"></div>
  <div class="relative max-w-5xl mx-auto px-5">
    <div class="rounded-[36px] border border-white/8 bg-white/[0.05] px-6 py-10 md:px-12 md:py-14 text-center backdrop-blur-sm shadow-[0_28px_70px_rgba(0,0,0,0.22)]">
      {variant === "mid" ? (
        <>
          <p class="text-brass text-xs tracking-[0.32em] mb-4 uppercase">Free Estimate</p>
          <h2 class="font-serif text-3xl md:text-5xl font-bold leading-[1.18] mb-5">
            まずは無料査定してみませんか？
          </h2>
          <p class="text-white/72 text-base md:text-lg leading-[1.9] max-w-2xl mx-auto mb-10">
            LINEなら写真を送るだけ。お電話なら最短30分でお伺いします。
          </p>
        </>
      ) : (
        <>
          <p class="text-brass text-xs tracking-[0.32em] mb-4 uppercase">Contact</p>
          <h2 class="font-serif text-3xl md:text-5xl font-bold leading-[1.18] mb-5">
            お問い合わせ
          </h2>
          <p class="text-white/72 text-base md:text-lg leading-[1.9] max-w-2xl mx-auto mb-10">
            「いくらになるか聞いてみたい」だけでも大歓迎です。しつこい営業は一切ありません。
          </p>
        </>
      )}

      <div class="flex flex-col sm:flex-row justify-center gap-3 mb-5">
        <a
          href="https://lin.ee/j4wK9IM"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-line px-8 py-4 text-sm md:text-base font-bold text-white shadow-[0_18px_40px_rgba(0,118,58,0.32)] hover:brightness-110 transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          写真を送って無料査定
        </a>
        <a
          href="tel:052-990-3968"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-white/14 bg-white/4 px-8 py-4 text-sm md:text-base font-bold text-white hover:border-white/28 hover:bg-white/7 transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.79 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          052-990-3968
        </a>
      </div>

      <p class="text-white/60 text-sm">
        完全無料 ・ しつこい営業なし ・ キャンセル料0円
      </p>
    </div>
  </div>
</section>
