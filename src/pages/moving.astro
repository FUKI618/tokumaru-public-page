---
import SpecializedLP from "../layouts/SpecializedLP.astro";
import CTASection from "../components/CTASection.astro";
---

<SpecializedLP
  title="名古屋の引越し不用品回収・買取｜徳丸商会"
  description="名古屋市で引越し時の不用品回収・買取なら徳丸商会。家電・家具をまとめて回収、買取額で処分費を相殺。即日対応・出張費0円。052-990-3968"
  slug="moving"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy via-navy-light to-navy text-white py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-5 text-center">
      <p class="text-gold text-xs md:text-sm font-bold mb-3">引越し時の不用品処分に</p>
      <h1 class="text-2xl md:text-5xl font-black leading-tight mb-4">
        引越し不用品を<br />
        <span class="text-gold">まるごと回収・買取</span>
      </h1>
      <p class="text-sm md:text-lg text-white/80 mb-6 leading-relaxed">
        処分にお金をかける必要はありません。買取額で処分費を相殺できます。
      </p>
      <div class="flex justify-center gap-4 md:gap-8">
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-black text-gold">即日<span class="text-sm">対応</span></p>
          <p class="text-[10px] md:text-xs text-white/60">引越し前日でもOK</p>
        </div>
        <div class="w-px bg-white/20"></div>
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-black text-gold">0<span class="text-sm">円</span></p>
          <p class="text-[10px] md:text-xs text-white/60">出張費・見積もり</p>
        </div>
      </div>
    </div>
  </section>

  <!-- こんな方に -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="text-xl md:text-3xl font-bold text-center text-navy mb-8">こんなお悩みありませんか？</h2>
      <div class="space-y-3">
        {[
          "引越し日が迫っているのに不用品が片付かない",
          "粗大ごみの回収日まで待てない",
          "家電リサイクル料を払うのがもったいない",
          "家電・家具をまとめて一度に処分したい",
          "新居に持っていけない大型家具がある",
        ].map((pain) => (
          <div class="flex items-start gap-3 bg-cream rounded-xl p-4">
            <span class="text-navy font-bold mt-0.5">✓</span>
            <p class="text-warm-gray text-sm">{pain}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-cta font-bold mt-6">すべて徳丸商会が解決します</p>
    </div>
  </section>

  <!-- 引越し買取の流れ -->
  <section class="py-12 md:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="text-xl md:text-3xl font-bold text-center text-navy mb-8">引越し不用品回収の流れ</h2>
      <div class="space-y-4">
        {[
          { step: "01", title: "お電話・LINEでご連絡", text: "引越し日と処分したいお品物をお伝えください。" },
          { step: "02", title: "訪問・査定・買取", text: "買取できるものは現金でお支払い。処分品もまとめてお引き取り。" },
          { step: "03", title: "搬出・清掃", text: "大型家具の搬出から簡易清掃まで対応。退去前にスッキリ。" },
        ].map((item) => (
          <div class="bg-white rounded-xl p-5 border border-cream-dark flex gap-4 items-start">
            <span class="bg-navy text-gold font-bold text-sm px-2.5 py-1 rounded-full flex-shrink-0">STEP {item.step}</span>
            <div>
              <h3 class="font-bold text-navy mb-1">{item.title}</h3>
              <p class="text-warm-gray text-sm leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection id="cta-mid" variant="mid" />
</SpecializedLP>
