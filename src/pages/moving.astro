---
import SpecializedLP from "../layouts/SpecializedLP.astro";
import CTASection from "../components/CTASection.astro";
import { homePath, pagePath } from "../lib/site";

const faqs = [
  { q: "引越し当日でも不用品回収をお願いできますか？", a: "はい、即日対応可能です。引越し前日や当日の急なご依頼にも柔軟に対応いたします。" },
  { q: "見積もりと実際の料金が変わることはありますか？", a: "お見積もり後の追加料金は一切ありません。現地確認後に正式な金額をお伝えし、ご了承いただいてから作業を開始します。" },
  { q: "買い取れるものがあれば回収費用から引いてもらえますか？", a: "はい、その場で査定し、回収費用から買取額を差し引きます。実質の負担額を大幅に減らせます。" },
  { q: "名古屋市の粗大ゴミ回収が間に合わないのですが…", a: "自治体の回収は予約が2〜3週間先になることもあります。当社なら即日から翌日での対応もご相談いただけます。" },
  { q: "エアコンの取り外しや大型家具の解体もできますか？", a: "エアコン取り外し、タンスの解体、ベッドの分解など、搬出に必要な作業まで対応いたします。" },
  { q: "土日祝日や夜間でも対応できますか？", a: "9:00〜21:00で年中無休対応しております。お仕事帰りの時間帯でもご依頼可能です。" },
];

const stats = [
  { label: "即日性", value: "最短当日", text: "引越し前日の相談にも対応" },
  { label: "見積もり", value: "0円", text: "出張費・査定費・キャンセル無料" },
  { label: "負担", value: "相殺", text: "買取額で回収費用を圧縮" },
];

const pains = [
  { title: "粗大ゴミが間に合わない", text: "自治体回収の予約より、引越し日が先に来てしまうケースです。" },
  { title: "冷蔵庫や洗濯機が重すぎる", text: "大型家電や家具を自力で運び出すのは現実的ではありません。" },
  { title: "処分費だけ払うのが惜しい", text: "まだ使える家電にお金を払って処分するのは避けたいという声が多いです。" },
  { title: "新居に持っていかない物が多い", text: "退去前にまとめて片付けたいが、業者を何社も分けて呼びたくない状況です。" },
];

const costExample = [
  { label: "不用品回収費用", value: "35,000円", tone: "text-ink" },
  { label: "家電買取（冷蔵庫 + 洗濯機）", value: "-28,000円", tone: "text-brass-dark" },
  { label: "実質お支払い", value: "7,000円", tone: "text-ink font-black text-2xl" },
];

const flow = [
  { title: "お電話・LINEでご相談", text: "引越し日と、回収したい物・売りたい物の概要をお知らせください。" },
  { title: "訪問・査定・仕分け", text: "買取できる物と回収品をその場で分け、金額をわかりやすくご案内します。" },
  { title: "搬出・精算", text: "大型家具や家電の搬出まで一括で対応し、最後に精算して完了です。" },
];

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const pageUrl = new URL(pagePath("moving"), siteUrl).toString();
const homeUrl = new URL(homePath, siteUrl).toString();

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: homeUrl },
      { "@type": "ListItem", position: 2, name: "引越し不用品回収・買取", item: pageUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "引越し不用品回収・買取",
    serviceType: "不用品回収・出張買取",
    areaServed: "名古屋市・近郊",
    provider: {
      "@type": "LocalBusiness",
      name: "徳丸商会",
      telephone: "052-990-3968",
      url: homeUrl,
    },
    url: pageUrl,
    description: "引越し時に出る不用品の回収と買取をまとめて行うサービスページ。即日対応にも対応。",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.a,
      },
    })),
  },
];
---

<SpecializedLP
  title="名古屋の引越し不用品回収・買取｜徳丸商会"
  description="名古屋市で引越し時の不用品回収・買取なら徳丸商会。家電・家具をまとめて回収、買取額で処分費を相殺。即日対応・出張費0円。052-990-3968"
  slug="moving"
  extraJsonLd={structuredData}
>
  <section class="relative overflow-hidden bg-[linear-gradient(180deg,#131920_0%,#181f28_56%,#212b35_100%)] text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(195,154,81,0.18),transparent_26%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.06),transparent_24%)]"></div>
    <div class="relative max-w-7xl mx-auto px-5 py-14 md:py-20">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.06fr)_minmax(320px,0.94fr)] items-end">
        <div>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="rounded-full border border-brass/35 bg-brass/12 px-3 py-1 text-[11px] font-bold tracking-[0.18em] text-brass uppercase">Moving Cleanup</span>
            <span class="rounded-full border border-white/10 bg-white/6 px-3 py-1 text-[11px] text-white/72">回収と買取を一度で整理</span>
          </div>
          <h1 class="font-serif text-[2.35rem] leading-[1.08] md:text-[4.3rem] mb-6">
            引越し前の不用品は、<br />
            <span class="text-brass">まとめて軽くする</span>のが最短です。
          </h1>
          <p class="max-w-2xl text-base md:text-lg leading-[1.9] text-white/76 mb-8">
            引越し直前の片付けは、回収と買取を別々に考えると間に合わなくなります。徳丸商会なら不要品の搬出、
            家電や家具の査定、実質費用の調整まで一度で対応できます。
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-8">
            {stats.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.05] px-5 py-4">
                <p class="text-white/45 text-[11px] tracking-[0.22em] uppercase mb-2">{item.label}</p>
                <p class="font-serif text-3xl leading-none text-white mb-2">{item.value}</p>
                <p class="text-sm leading-[1.7] text-white/68">{item.text}</p>
              </div>
            ))}
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="#cta-mid" class="inline-flex items-center justify-center rounded-full bg-brass px-7 py-4 text-sm md:text-base font-bold text-ink shadow-[0_18px_40px_rgba(195,154,81,0.28)] hover:bg-brass-light transition-colors">引越し前に相談する</a>
            <a href="tel:052-990-3968" class="inline-flex items-center justify-center rounded-full border border-white/14 bg-white/4 px-7 py-4 text-sm md:text-base font-bold text-white hover:border-white/28 hover:bg-white/7 transition-all">電話で相談する 052-990-3968</a>
          </div>
        </div>

        <div class="rounded-[30px] border border-white/10 bg-white/[0.05] p-6 md:p-7 shadow-[0_28px_70px_rgba(0,0,0,0.24)] backdrop-blur-sm">
          <p class="text-brass text-[11px] tracking-[0.22em] uppercase mb-3">Direct Answer</p>
          <h2 class="font-serif text-2xl md:text-[2rem] leading-tight mb-5">このページの結論だけ先に。</h2>
          <div class="space-y-3">
            {[
              "粗大ゴミ回収が間に合わなくても、当日まで相談できます。",
              "買取できる家電があれば、回収費用と相殺できます。",
              "大型家具やエアコンの取り外しも一緒に頼めます。",
            ].map((point) => (
              <div class="rounded-2xl border border-white/8 bg-white/[0.04] px-4 py-4 text-sm leading-[1.8] text-white/76">{point}</div>
            ))}
          </div>
          <div class="mt-5 rounded-[24px] bg-sand px-5 py-5 text-ink">
            <p class="text-[11px] tracking-[0.18em] uppercase text-graphite-light mb-2">相談しやすいケース</p>
            <p class="font-bold text-base mb-2">引越し前日 / 退去目前 / 買い替え直前</p>
            <p class="text-sm leading-[1.8] text-graphite-light">急ぎの案件でも、回収と査定を切り分けずに進められます。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-10 -mt-7 md:-mt-9">
    <div class="max-w-7xl mx-auto px-5">
      <div class="grid gap-3 md:grid-cols-3">
        {[
          { title: "処分先を分けなくていい", text: "回収業者、買取業者、自治体回収を分けて探す必要がありません。" },
          { title: "費用だけの処分を避けやすい", text: "まだ売れる家電や家具があれば、先に査定して相殺できます。" },
          { title: "引越し日から逆算しやすい", text: "何をいつまでに出すかが整理しやすく、段取りが崩れません。" },
        ].map((item) => (
          <div class="rounded-[26px] border border-sand-dark bg-white px-6 py-6 shadow-[0_22px_45px_rgba(18,24,30,0.08)]">
            <p class="text-ink font-bold text-lg mb-2">{item.title}</p>
            <p class="text-sm leading-[1.8] text-graphite-light">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-5">
      <div class="grid gap-10 lg:grid-cols-[0.88fr_1.12fr] items-start">
        <div class="rounded-[32px] border border-sand-dark bg-sand px-7 py-8 md:px-10 md:py-10">
          <p class="text-graphite text-xs tracking-[0.32em] uppercase mb-4">Pain Points</p>
          <h2 class="font-serif text-3xl md:text-5xl text-ink leading-[1.14] mb-5">
            引越し前に詰まりやすいポイントを、<br />先回りして整理。
          </h2>
          <p class="text-base leading-[1.9] text-graphite-light">
            以前のページは単なる箇条書きで、問題の強さが伝わりませんでした。
            ここでは実際に詰まりやすい状況を整理し、依頼理由が見える構成に変えています。
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {pains.map((item) => (
            <div class="rounded-[28px] border border-sand-dark bg-white px-6 py-7 shadow-[0_18px_40px_rgba(18,24,30,0.05)]">
              <h3 class="text-lg font-bold leading-snug text-ink mb-3">{item.title}</h3>
              <p class="text-sm leading-[1.85] text-graphite-light">{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[linear-gradient(180deg,#171d26_0%,#10151c_100%)] text-white">
    <div class="max-w-7xl mx-auto px-5">
      <div class="md:flex md:items-end md:justify-between gap-10 mb-10 md:mb-14">
        <div>
          <p class="text-brass-light text-xs tracking-[0.32em] uppercase mb-4">Cost Example</p>
          <h2 class="font-serif text-3xl md:text-5xl leading-[1.14]">「処分費だけ払う」を、<br />避けられることがあります</h2>
        </div>
        <p class="max-w-xl text-sm md:text-base leading-[1.9] text-white/70">
          金額例を中央に置いて、ページの説得力を上げています。LPは抽象論だけだと弱いです。
        </p>
      </div>
      <div class="grid gap-6 xl:grid-cols-[0.94fr_1.06fr] items-start">
        <div class="rounded-[30px] border border-white/8 bg-white/[0.05] px-6 py-7 shadow-[0_18px_40px_rgba(0,0,0,0.16)]">
          <div class="space-y-4">
            {costExample.map((item, index) => (
              <div class={index === costExample.length - 1 ? "border-t border-white/12 pt-4 flex items-center justify-between gap-4" : "flex items-center justify-between gap-4"}>
                <span class="text-sm md:text-base text-white/72">{item.label}</span>
                <span class={item.tone}>{item.value}</span>
              </div>
            ))}
          </div>
          <p class="mt-5 text-xs leading-[1.8] text-white/55">※金額は一例です。内容、点数、搬出条件により変動します。</p>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {flow.map((item, index) => (
            <div class="rounded-[28px] border border-white/8 bg-white/[0.05] px-6 py-7">
              <p class="text-brass text-sm font-bold mb-4">STEP {index + 1}</p>
              <h3 class="text-lg font-bold leading-snug mb-3">{item.title}</h3>
              <p class="text-sm leading-[1.85] text-white/68">{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection id="cta-mid" variant="mid" />

  <section class="py-20 md:py-28 bg-sand-light">
    <div class="max-w-4xl mx-auto px-5">
      <div class="text-center mb-10">
        <p class="text-graphite text-xs tracking-[0.32em] uppercase mb-4">FAQ</p>
        <h2 class="font-serif text-3xl md:text-5xl text-ink leading-[1.14]">引越し不用品の回収・買取で<br />よくある質問</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <div x-data="{ open: false }" class="rounded-[26px] border border-sand-dark bg-white shadow-[0_16px_36px_rgba(18,24,30,0.04)] overflow-hidden">
            <button x-on:click="open = !open" class="w-full flex items-start justify-between gap-4 px-5 py-5 text-left" x-bind:aria-expanded="open.toString()">
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-ink text-xs font-bold text-white">Q</span>
                <span class="text-sm md:text-base font-bold leading-[1.7] text-ink">{faq.q}</span>
              </div>
              <span class="mt-1 text-2xl leading-none text-brass" x-text="open ? '−' : '+'"></span>
            </button>
            <div x-show="open" x-transition style="display: none;" class="px-5 pb-5">
              <div class="flex items-start gap-3 border-t border-sand-dark pt-4">
                <span class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-brass text-xs font-bold text-ink">A</span>
                <p class="text-sm md:text-base leading-[1.9] text-graphite-light">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</SpecializedLP>
