---
import Layout from "../layouts/Layout.astro";
import { assetPath, homePath, sectionPath, privacyPolicyPath } from "../lib/site";
import { faqs } from "../data/faq";

const logoUrl = assetPath("logo.png");
const beforeImg = assetPath("images/before.png");
const afterImg = assetPath("images/after.png");

const buyItems = [
  { name: "腕時計", img: assetPath("images/items/watch.png") },
  { name: "ブランド品", img: assetPath("images/items/brand.png") },
  { name: "貴金属", img: assetPath("images/items/metals.png") },
  { name: "エアコン", img: assetPath("images/items/aircon.png") },
  { name: "冷蔵庫", img: assetPath("images/items/fridge.png") },
  { name: "ドラム式洗濯機", img: assetPath("images/items/washer.png") },
  { name: "電子レンジ", img: assetPath("images/items/microwave.png") },
  { name: "楽器", img: assetPath("images/items/guitar.png") },
];

const results = [
  { name: "冷蔵庫", detail: "大型 500L以上", price: "39,000", image: assetPath("images/results/refrigerator.jpg") },
  { name: "洗濯機", detail: "ドラム式洗濯乾燥機", price: "24,500", image: assetPath("images/results/washing-machine.jpg") },
  { name: "エアコン", detail: "ルームエアコン 取外込", price: "21,000", image: assetPath("images/results/aircon.jpg") },
  { name: "テレビ", detail: "液晶テレビ 55インチ", price: "17,000", image: assetPath("images/results/tv.jpg") },
];

const testimonials = [
  { text: "引越し前日に慌てて電話しましたが、2時間後には全部片付きました。思った以上の金額で買い取ってもらえて助かりました。", name: "T.S様", area: "名古屋市中区" },
  { text: "LINEで写真を送ったらすぐに概算が出て、翌日には訪問してもらえました。重い冷蔵庫の搬出も手際よくて、お願いして本当によかったです。", name: "M.K様", area: "名古屋市緑区" },
  { text: "他社で断られた古い家具も査定してくれて、値段がついたのは驚きでした。スタッフの方も丁寧で、家族にも勧めています。", name: "Y.N様", area: "あま市" },
];

const areas = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearby = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市"];
---

<Layout
  title="名古屋の出張買取なら徳丸商会｜家電・家具を高額買取・出張費無料"
  description="名古屋市・近郊エリアの出張買取は徳丸商会へ。家電・家具・ブランド品をその場で現金買取。出張費・査定費0円、最短30分で訪問。052-990-3968"
>

<!-- HEADER -->
<header class="fixed top-0 inset-x-0 z-50 bg-ink/95 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-5 h-14 flex items-center justify-between">
    <a href={homePath} class="flex items-center gap-2">
      <img src={logoUrl} alt="徳丸商会" width="30" height="30" class="w-[30px] h-[30px]" style="filter: drop-shadow(0 0 2px rgba(184,146,74,0.4));" />
      <span class="text-white font-bold text-sm">徳丸商会</span>
    </a>
    <div class="flex items-center gap-4">
      <nav class="hidden md:flex items-center gap-6 text-xs text-white/40 tracking-wider uppercase">
        <a href={sectionPath("service")} class="hover:text-brass transition-colors">サービス</a>
        <a href={sectionPath("items")} class="hover:text-brass transition-colors">買取品目</a>
        <a href={sectionPath("results")} class="hover:text-brass transition-colors">実績</a>
        <a href={sectionPath("faq")} class="hover:text-brass transition-colors">FAQ</a>
      </nav>
      <div class="flex items-center gap-2">
        <a href="tel:052-990-3968" class="text-white/50 hover:text-white text-xs transition-colors hidden sm:block">052-990-3968</a>
        <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-brass text-ink text-xs font-bold px-3.5 py-1.5 rounded-sm hover:bg-brass-light transition-colors">無料査定</a>
      </div>
    </div>
  </div>
</header>

<main class="pt-14">

<!-- ═══ HERO: フルスクリーン、大胆なタイポグラフィ ═══ -->
<section class="relative bg-ink text-white overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-ink via-ink to-ink-light"></div>
  <!-- 巨大装飾テキスト -->
  <div class="absolute -right-10 bottom-0 text-[15rem] md:text-[25rem] font-serif font-bold text-white/[0.015] leading-none select-none pointer-events-none" aria-hidden="true">徳</div>

  <div class="relative max-w-7xl mx-auto px-5 pt-24 pb-16 md:pt-36 md:pb-24">
    <p class="text-brass/80 text-xs md:text-xs tracking-[0.4em] mb-8 uppercase">名古屋 出張買取サービス</p>

    <h1 class="font-serif text-[2.2rem] md:text-[4rem] lg:text-[5rem] font-bold leading-[1.1] mb-8 max-w-3xl">
      不用品を、<br /><span class="text-brass">価値</span>に変える。
    </h1>

    <p class="text-white/50 text-sm md:text-base leading-[2] mb-12 max-w-lg">
      中古家電・家具・ブランド品をご自宅でその場で査定。愛知県名古屋市を中心に、出張費無料・即日対応でお伺いします。
    </p>

    <!-- 数字バー -->
    <div class="flex flex-wrap gap-6 md:gap-14 mb-12">
      <div>
        <p class="font-serif text-4xl md:text-6xl font-bold text-white leading-none">1,200<span class="text-brass text-xl">+</span></p>
        <p class="text-white/25 text-xs mt-2 tracking-wider">累計買取件数</p>
      </div>
      <div>
        <p class="font-serif text-4xl md:text-6xl font-bold text-white leading-none">98<span class="text-brass text-xl">%</span></p>
        <p class="text-white/25 text-xs mt-2 tracking-wider">お客様満足度</p>
      </div>
    </div>

    <!-- CTA -->
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer"
        class="group inline-flex items-center justify-center gap-2 bg-brass hover:bg-brass-light text-ink font-bold text-sm px-8 py-4 rounded-sm transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596a.629.629 0 0 1-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595a.63.63 0 0 1 .495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
        写真を送って無料査定
      </a>
      <a href="tel:052-990-3968"
        class="inline-flex items-center justify-center gap-2 text-white/40 hover:text-white text-sm px-8 py-4 border border-white/10 hover:border-white/25 rounded-sm transition-all">
        052-990-3968
      </a>
    </div>

    <p class="text-white/20 text-xs mt-5 tracking-wide">出張費0円 / 査定のみOK / キャンセル無料 / 9:00-21:00 年中無休</p>
  </div>
</section>

<!-- ═══ 3つの約束 ═══ -->
<section class="bg-sand border-y border-sand-dark">
  <div class="max-w-7xl mx-auto grid grid-cols-3 divide-x divide-sand-dark">
    {[
      { big: "30分", sub: "最短訪問" },
      { big: "0円", sub: "出張費・見積もり" },
      { big: "現金", sub: "その場で即払い" },
    ].map((p) => (
      <div class="py-6 md:py-10 text-center">
        <p class="font-serif text-xl md:text-3xl font-bold text-ink">{p.big}</p>
        <p class="text-graphite-light text-xs md:text-xs mt-1">{p.sub}</p>
      </div>
    ))}
  </div>
</section>

<!-- ═══ サービス ═══ -->
<section id="service" class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-5">
    <div class="md:grid md:grid-cols-5 md:gap-16">
      <div class="md:col-span-2 mb-10 md:mb-0">
        <p class="text-brass text-xs tracking-[0.3em] mb-4 uppercase">Service</p>
        <h2 class="font-serif text-2xl md:text-4xl font-bold text-ink leading-[1.2] mb-5">
          なぜ<br />徳丸商会が<br />選ばれるのか
        </h2>
        <p class="text-graphite-light text-sm md:text-base leading-[2]">
          出張買取とは、ご自宅にスタッフが訪問し不用品をその場で査定・買取するサービスです。
        </p>
      </div>
      <div class="md:col-span-3">
        {[
          { n: "01", title: "完全無料の出張査定", text: "出張費・見積もり・キャンセル料、すべて0円。買取が成立しなくても一切費用はかかりません。" },
          { n: "02", title: "最短30分の即日対応", text: "お電話一本でスタッフが駆けつけます。引越し直前や急な片付けにも柔軟に対応いたします。" },
          { n: "03", title: "その場で現金払い", text: "査定額にご納得いただければ、その場で現金をお渡し。後日振込を待つ必要はありません。" },
          { n: "04", title: "搬出もすべてお任せ", text: "冷蔵庫やタンスなどの重量物も丁寧に搬出。養生シートで壁・床を保護します。" },
        ].map((s) => (
          <div class="border-b border-sand-dark py-7 md:py-9 group">
            <div class="flex items-start gap-5">
              <span class="font-serif text-3xl font-bold text-sand-dark group-hover:text-brass transition-colors">{s.n}</span>
              <div>
                <h3 class="font-bold text-ink text-base md:text-lg mb-2">{s.title}</h3>
                <p class="text-graphite-light text-sm md:text-base leading-[1.9]">{s.text}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ═══ 買取アイテム（画像グリッド）═══ -->
<section id="items" class="py-20 md:py-32 bg-ink text-white">
  <div class="max-w-7xl mx-auto px-5">
    <p class="text-brass text-xs tracking-[0.3em] mb-4 uppercase">Purchase Items</p>
    <div class="md:flex md:items-end md:justify-between mb-10 md:mb-14">
      <h2 class="font-serif text-2xl md:text-4xl font-bold leading-[1.2] mb-4 md:mb-0">
        高価買取<br />対応アイテム
      </h2>
      <p class="text-white/35 text-sm max-w-sm">家電からブランド品・貴金属まで、幅広いジャンルを出張買取いたします。</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 md:gap-4">
      {buyItems.map((item) => (
        <div class="group relative rounded overflow-hidden aspect-square flex items-center justify-center p-8 hover:scale-[1.02] transition-transform duration-300" style="background-color: #f5f0e8;">
          <img src={item.img} alt={`${item.name}の買取`} width="200" height="200"
            class="w-full h-full object-contain drop-shadow-md" loading="lazy" />
          <p class="absolute bottom-0 inset-x-0 bg-ink/80 text-white text-xs font-bold text-center py-2">{item.name}</p>
        </div>
      ))}
    </div>
    <p class="text-white/20 text-xs mt-6">ゲーム機・香水・高級家具ほか、上記以外のお品物もお気軽にご相談ください</p>
  </div>
</section>

<!-- ═══ 買取実績 ═══ -->
<section id="results" class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-5">
    <p class="text-brass text-xs tracking-[0.3em] mb-4 uppercase">Track Record</p>
    <h2 class="font-serif text-2xl md:text-4xl font-bold text-ink leading-[1.2] mb-10 md:mb-14">
      高額買取実績
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-8">
      {results.map((r) => (
        <div>
          <div class="aspect-[4/3] overflow-hidden bg-sand rounded-sm mb-4">
            <img src={r.image} alt={`${r.name}の買取実績`} width="400" height="300" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <p class="text-graphite-light text-xs tracking-wider uppercase">{r.detail}</p>
          <p class="text-ink font-bold text-sm mt-0.5">{r.name}</p>
          <p class="font-serif text-brass-dark text-2xl font-bold mt-1">¥{r.price}<span class="text-sm text-graphite-light font-normal">〜</span></p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ ビフォーアフター ═══ -->
<section class="py-20 md:py-32 bg-sand">
  <div class="max-w-6xl mx-auto px-5">
    <p class="text-brass text-xs tracking-[0.3em] mb-4 uppercase">Before &amp; After</p>
    <h2 class="font-serif text-2xl md:text-4xl font-bold text-ink leading-[1.2] mb-10 md:mb-14">まるっと回収</h2>
    <div class="grid grid-cols-2 gap-3 md:gap-6 max-w-4xl">
      <div>
        <div class="overflow-hidden rounded-sm"><img src={beforeImg} alt="買取前" width="600" height="400" class="w-full" loading="lazy" /></div>
        <p class="text-graphite-light text-xs tracking-wider uppercase mt-2">Before</p>
      </div>
      <div>
        <div class="overflow-hidden rounded-sm"><img src={afterImg} alt="買取後" width="600" height="400" class="w-full" loading="lazy" /></div>
        <p class="text-graphite-light text-xs tracking-wider uppercase mt-2">After</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ お客様の声 ═══ -->
<section id="testimonials" class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-5">
    <p class="text-brass text-xs tracking-[0.3em] mb-4 uppercase">Voice</p>
    <h2 class="font-serif text-2xl md:text-4xl font-bold text-ink leading-[1.2] mb-10 md:mb-14">お客様の声</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {testimonials.map((t) => (
        <div class="border-l-2 border-brass/30 pl-5">
          <blockquote class="text-graphite text-sm md:text-base leading-[2] mb-4">{t.text}</blockquote>
          <p class="text-graphite-light text-xs">{t.area}　{t.name}</p>
        </div>
      ))}
    </div>
    <p class="text-center text-graphite-light text-xs mt-10">お客様満足度 <strong class="text-ink">98%</strong>（自社調べ）</p>
  </div>
</section>

<!-- ═══ 対応エリア ═══ -->
<section id="area" class="py-20 md:py-32 bg-sand">
  <div class="max-w-6xl mx-auto px-5">
    <p class="text-brass text-xs tracking-[0.3em] mb-4 uppercase">Area</p>
    <h2 class="font-serif text-2xl md:text-4xl font-bold text-ink leading-[1.2] mb-10 md:mb-14">対応エリア</h2>
    <div class="md:flex md:gap-20">
      <div class="mb-8 md:mb-0">
        <h3 class="text-ink font-bold text-xs tracking-wider mb-4">名古屋市（16区）</h3>
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-graphite-light text-sm md:text-base">{areas.map((w) => <span>{w}</span>)}</div>
      </div>
      <div>
        <h3 class="text-ink font-bold text-xs tracking-wider mb-4">近郊エリア</h3>
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-graphite-light text-sm md:text-base">{nearby.map((a) => <span>{a}</span>)}</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ FAQ ═══ -->
<section id="faq" class="py-20 md:py-32">
  <div class="max-w-3xl mx-auto px-5">
    <p class="text-brass text-xs tracking-[0.3em] mb-4 uppercase">FAQ</p>
    <h2 class="font-serif text-2xl md:text-4xl font-bold text-ink leading-[1.2] mb-10 md:mb-14">よくあるご質問</h2>
    <div class="divide-y divide-sand-dark">
      {faqs.map((faq) => (
        <div x-data="{ open: false }">
          <button x-on:click="open = !open" class="w-full flex items-start justify-between gap-4 py-6 text-left" x-bind:aria-expanded="open.toString()">
            <span class="text-ink font-bold text-sm md:text-base leading-relaxed">{faq.question}</span>
            <span class="text-brass text-lg flex-shrink-0 transition-transform duration-300 leading-none" x-bind:class="open && 'rotate-45'">+</span>
          </button>
          <div x-show="open" x-transition class="pb-6" style="display: none;">
            <p class="text-graphite-light text-sm md:text-base leading-[2]">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ CONTACT ═══ -->
<section id="contact" class="py-24 md:py-36 bg-ink text-white text-center relative overflow-hidden">
  <div class="absolute inset-0 text-[20rem] font-serif font-bold text-white/[0.01] leading-none flex items-center justify-center select-none pointer-events-none" aria-hidden="true">買取</div>
  <div class="relative max-w-2xl mx-auto px-5">
    <p class="text-brass text-xs tracking-[0.3em] mb-4 uppercase">Contact</p>
    <h2 class="font-serif text-2xl md:text-4xl font-bold leading-snug mb-5">
      まずは、お気軽に。
    </h2>
    <p class="text-white/35 text-sm mb-10">
      「いくらになるか聞いてみたい」だけでも大歓迎です。<br class="hidden md:inline" />しつこい営業は一切ありません。
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-3 mb-5">
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-brass hover:bg-brass-light text-ink font-bold text-sm px-8 py-4 rounded-sm transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596a.629.629 0 0 1-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595a.63.63 0 0 1 .495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
        無料査定を申し込む
      </a>
      <a href="tel:052-990-3968" class="inline-flex items-center justify-center gap-2 text-white/40 hover:text-white text-sm px-8 py-4 border border-white/10 hover:border-white/25 rounded-sm transition-all">052-990-3968</a>
    </div>
    <p class="text-white/15 text-xs">受付 9:00-21:00 年中無休 ｜ 古物商許可 第541042309800号</p>
  </div>
</section>

</main>

<!-- FOOTER -->
<footer class="bg-ink-light text-white/30 py-14">
  <div class="max-w-6xl mx-auto px-5 md:flex md:justify-between md:items-start gap-12">
    <div class="mb-8 md:mb-0">
      <div class="flex items-center gap-2 mb-3">
        <img src={logoUrl} alt="徳丸商会" width="24" height="24" class="w-6 h-6" style="filter: drop-shadow(0 0 2px rgba(184,146,74,0.3));" />
        <span class="text-white/60 font-bold text-xs">徳丸商会</span>
      </div>
      <p class="text-xs">名古屋市・近郊エリアの出張買取</p>
      <p class="text-xs">古物商許可 第541042309800号</p>
    </div>
    <div class="flex gap-12 text-xs">
      <div>
        <p class="text-white/40 text-xs tracking-[0.2em] uppercase mb-3">Contact</p>
        <a href="tel:052-990-3968" class="block hover:text-white/60 transition-colors">052-990-3968</a>
        <p>9:00-21:00（年中無休）</p>
        <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="hover:text-white/60 transition-colors">LINE公式</a>
      </div>
      <div>
        <p class="text-white/40 text-xs tracking-[0.2em] uppercase mb-3">Pages</p>
        <nav class="flex flex-col gap-1">
          <a href={sectionPath("service")} class="hover:text-white/60 transition-colors">サービス</a>
          <a href={sectionPath("items")} class="hover:text-white/60 transition-colors">買取品目</a>
          <a href={privacyPolicyPath} class="hover:text-white/60 transition-colors">プライバシーポリシー</a>
        </nav>
      </div>
    </div>
  </div>
  <div class="max-w-6xl mx-auto px-5 mt-10 pt-6 border-t border-white/5 pb-16 md:pb-0 text-center text-xs text-white/10">
    &copy; {new Date().getFullYear()} 徳丸商会
  </div>
</footer>

<!-- FLOATING CTA -->
<div x-data="{ show: false }" x-init="window.addEventListener('scroll', () => { show = window.scrollY > 400 })" x-show="show" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full" class="fixed bottom-0 inset-x-0 z-50 md:hidden bg-ink/95 backdrop-blur-md border-t border-white/5" style="display: none;">
  <div class="flex gap-2 px-4 py-3">
    <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 bg-brass text-ink font-bold py-3 rounded-sm text-xs">LINE査定</a>
    <a href="tel:052-990-3968" class="flex-1 flex items-center justify-center gap-2 border border-white/15 text-white font-bold py-3 rounded-sm text-xs">電話する</a>
  </div>
</div>

</Layout>
