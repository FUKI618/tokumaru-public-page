---
import Layout from "../layouts/Layout.astro";
import { assetPath, homePath, sectionPath, privacyPolicyPath } from "../lib/site";
import { faqs } from "../data/faq";

const logoUrl = assetPath("logo.png");
const beforeImg = assetPath("images/before.png");
const afterImg = assetPath("images/after.png");

const buyItems = [
  { name: "腕時計", img: assetPath("images/items/watch.png") },
  { name: "ブランド品", img: assetPath("images/items/brand.png") },
  { name: "貴金属", img: assetPath("images/items/metals.png") },
  { name: "エアコン", img: assetPath("images/items/aircon.png") },
  { name: "冷蔵庫", img: assetPath("images/items/fridge.png") },
  { name: "ドラム式洗濯機", img: assetPath("images/items/washer.png") },
  { name: "電子レンジ", img: assetPath("images/items/microwave.png") },
  { name: "楽器", img: assetPath("images/items/guitar.png") },
];

const results = [
  { name: "冷蔵庫", detail: "大型 500L以上", price: "39,000", image: assetPath("images/results/refrigerator.jpg") },
  { name: "洗濯機", detail: "ドラム式洗濯乾燥機", price: "24,500", image: assetPath("images/results/washing-machine.jpg") },
  { name: "エアコン", detail: "ルームエアコン 取外込", price: "21,000", image: assetPath("images/results/aircon.jpg") },
  { name: "テレビ", detail: "液晶テレビ 55インチ", price: "17,000", image: assetPath("images/results/tv.jpg") },
];

const testimonials = [
  { text: "引越し前日に慌てて電話しましたが、2時間後には全部片付きました。思った以上の金額で買い取ってもらえて助かりました。", name: "T.S様", area: "名古屋市中区" },
  { text: "LINEで写真を送ったらすぐに概算が出て、翌日には訪問してもらえました。重い冷蔵庫の搬出も手際よくて、お願いして本当によかったです。", name: "M.K様", area: "名古屋市緑区" },
  { text: "他社で断られた古い家具も査定してくれて、値段がついたのは驚きでした。スタッフの方も丁寧で、家族にも勧めています。", name: "Y.N様", area: "あま市" },
];

const areas = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearby = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市"];

const strengths = [
  { label: "最短", value: "30分", text: "お問い合わせ後、最短30分で訪問" },
  { label: "費用", value: "0円", text: "出張費・査定費・キャンセル料すべて無料" },
  { label: "支払い", value: "即日", text: "ご納得いただければその場で現金払い" },
];

const serviceCards = [
  { n: "01", title: "完全無料の出張査定", text: "出張費・見積もり・キャンセル料はすべて0円。査定だけのご相談でも気兼ねなく依頼できます。" },
  { n: "02", title: "最短30分の即日対応", text: "引越し前、家じまい、急な片付けにも対応。名古屋市内ならスピード感を持ってお伺いします。" },
  { n: "03", title: "その場で現金お支払い", text: "査定額にご納得いただければ、その場で現金をお渡し。後日の振込待ちはありません。" },
  { n: "04", title: "搬出までまるごと対応", text: "重い冷蔵庫や大型家具も、スタッフが養生から搬出まで丁寧に対応します。" },
];
---

<Layout
  title="名古屋の出張買取なら徳丸商会｜家電・家具を高額買取・出張費無料"
  description="名古屋市・近郊エリアの出張買取は徳丸商会へ。家電・家具・ブランド品をその場で現金買取。出張費・査定費0円、最短30分で訪問。052-990-3968"
>
  <header class="fixed top-0 inset-x-0 z-50 border-b border-white/8 bg-ink/88 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-5 h-16 md:h-[72px] flex items-center justify-between gap-4">
      <a href={homePath} class="flex items-center gap-3 min-w-0">
        <img
          src={logoUrl}
          alt="徳丸商会"
          width="36"
          height="36"
          class="w-9 h-9 rounded-sm bg-white object-contain"
        />
        <div class="min-w-0">
          <p class="text-white font-bold text-sm md:text-base leading-none">徳丸商会</p>
          <p class="text-white/60 text-[10px] md:text-xs mt-1">名古屋・近郊の出張買取サービス</p>
        </div>
      </a>

      <div class="flex items-center gap-4 md:gap-6">
        <nav class="hidden lg:flex items-center gap-6 text-[13px] text-white/60">
          <a href={sectionPath("service")} class="hover:text-white transition-colors">サービス</a>
          <a href={sectionPath("items")} class="hover:text-white transition-colors">買取品目</a>
          <a href={sectionPath("results")} class="hover:text-white transition-colors">買取実績</a>
          <a href={sectionPath("faq")} class="hover:text-white transition-colors">FAQ</a>
        </nav>

        <div class="flex items-center gap-2 md:gap-3">
          <a href="tel:052-990-3968" class="hidden md:inline text-white/75 hover:text-white text-sm transition-colors">
            052-990-3968
          </a>
          <a
            href="https://lin.ee/j4wK9IM"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-brass px-4 py-2 text-[13px] font-bold text-ink shadow-[0_12px_30px_rgba(184,146,74,0.28)] hover:bg-brass-light transition-colors"
          >
            無料査定
          </a>
        </div>
      </div>
    </div>
  </header>

  <main class="pt-16 md:pt-[72px]">
    <section class="relative overflow-hidden bg-ink text-white">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(184,146,74,0.18),transparent_34%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.05),transparent_26%),linear-gradient(180deg,#131920_0%,#141b23_54%,#1b2430_100%)]"></div>
      <div class="absolute inset-y-0 right-[-6rem] hidden md:block w-[36rem] bg-[radial-gradient(circle,rgba(184,146,74,0.08),transparent_62%)]"></div>
      <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black/15 to-transparent"></div>

      <div class="relative max-w-7xl mx-auto px-5 pt-14 pb-18 md:pt-20 md:pb-24">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] lg:items-end">
          <div>
            <div class="flex flex-wrap gap-2 mb-6">
              <span class="inline-flex items-center rounded-full border border-brass/35 bg-brass/10 px-3 py-1 text-[11px] font-bold tracking-[0.18em] text-brass uppercase">
                名古屋の出張買取
              </span>
              <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] font-medium text-white/75">
                家電・家具・ブランド品に対応
              </span>
            </div>

            <h1 class="font-serif text-[2.6rem] leading-[1.05] md:text-[4.5rem] lg:text-[5.25rem] mb-6 max-w-4xl">
              名古屋での不用品買取を、<br />
              <span class="text-brass">もっと早く、もっと納得感ある形で。</span>
            </h1>

            <p class="max-w-2xl text-base md:text-lg leading-[1.9] text-white/76 mb-8">
              冷蔵庫・洗濯機・エアコン・ブランド品などを、
              ご自宅でその場で査定。出張費無料、最短30分で訪問し、
              金額にご納得いただければその場で現金でお支払いします。
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-8 md:mb-10">
              {strengths.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/[0.045] px-5 py-4 backdrop-blur-sm">
                  <p class="text-white/45 text-[11px] tracking-[0.22em] uppercase mb-2">{item.label}</p>
                  <p class="font-serif text-3xl md:text-[2.35rem] leading-none text-white mb-2">
                    {item.value}
                  </p>
                  <p class="text-sm leading-[1.7] text-white/68">{item.text}</p>
                </div>
              ))}
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href="https://lin.ee/j4wK9IM"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 rounded-full bg-line px-7 py-4 text-sm md:text-base font-bold text-white shadow-[0_18px_40px_rgba(0,138,67,0.32)] hover:brightness-110 transition-all"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596a.629.629 0 0 1-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595a.63.63 0 0 1 .495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
                写真を送って無料査定
              </a>
              <a
                href="tel:052-990-3968"
                class="inline-flex items-center justify-center gap-2 rounded-full border border-white/14 bg-white/4 px-7 py-4 text-sm md:text-base font-bold text-white hover:border-white/28 hover:bg-white/7 transition-all"
              >
                今すぐ電話する 052-990-3968
              </a>
            </div>

            <p class="mt-5 text-sm text-white/58">
              出張費0円 / 査定のみOK / キャンセル無料 / 9:00〜21:00 年中無休
            </p>
          </div>

          <div class="lg:pb-2">
            <div class="rounded-[28px] border border-white/10 bg-white/[0.05] p-6 md:p-7 backdrop-blur-md shadow-[0_28px_70px_rgba(0,0,0,0.22)]">
              <div class="flex items-center justify-between gap-4 mb-6">
                <div>
                  <p class="text-brass text-[11px] tracking-[0.22em] uppercase mb-2">Tokumaru Value</p>
                  <h2 class="font-serif text-2xl md:text-[2rem] leading-tight">出張買取で迷わせないための、3つの基準</h2>
                </div>
                <div class="hidden md:flex h-12 w-12 items-center justify-center rounded-full border border-brass/30 bg-brass/10 text-brass font-serif text-xl">
                  徳
                </div>
              </div>

              <div class="space-y-4">
                <div class="rounded-2xl bg-white/[0.04] px-4 py-4 border border-white/8">
                  <p class="text-white text-sm font-bold mb-1">1. 価格だけでなく、対応の速さまで明確</p>
                  <p class="text-white/62 text-sm leading-[1.75]">最短30分訪問、即日対応可。急ぎの片付けにも具体的な時間感で応えます。</p>
                </div>
                <div class="rounded-2xl bg-white/[0.04] px-4 py-4 border border-white/8">
                  <p class="text-white text-sm font-bold mb-1">2. お金の不安を先に潰す</p>
                  <p class="text-white/62 text-sm leading-[1.75]">出張費・査定費・キャンセル料はすべて無料。相談の時点で損をしません。</p>
                </div>
                <div class="rounded-2xl bg-white/[0.04] px-4 py-4 border border-white/8">
                  <p class="text-white text-sm font-bold mb-1">3. 家電も家具も搬出まで任せられる</p>
                  <p class="text-white/62 text-sm leading-[1.75]">大型冷蔵庫やタンスも、養生から運び出しまでスタッフが対応します。</p>
                </div>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-2xl bg-sand px-4 py-4 text-ink">
                  <p class="text-[11px] tracking-[0.18em] uppercase text-graphite-light mb-1">対応地域</p>
                  <p class="font-bold text-base">名古屋市16区 + 近郊</p>
                </div>
                <div class="rounded-2xl bg-brass px-4 py-4 text-ink">
                  <p class="text-[11px] tracking-[0.18em] uppercase text-ink/85 mb-1">受付時間</p>
                  <p class="font-bold text-base">9:00〜21:00 年中無休</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="relative z-10 -mt-8 md:-mt-10">
      <div class="max-w-7xl mx-auto px-5">
        <div class="grid gap-3 md:grid-cols-3 md:gap-5">
          {[
            { big: "30分", sub: "最短訪問", detail: "名古屋市内ならスピード対応" },
            { big: "0円", sub: "出張費・見積もり", detail: "査定だけでも費用はかかりません" },
            { big: "現金", sub: "その場で即払い", detail: "ご納得後すぐにお支払い" },
          ].map((p) => (
            <div class="rounded-[26px] border border-sand-dark bg-white px-6 py-6 md:px-7 md:py-7 shadow-[0_22px_45px_rgba(18,24,30,0.08)]">
              <p class="font-serif text-3xl md:text-[2.7rem] leading-none text-ink">{p.big}</p>
              <p class="mt-2 text-sm font-bold text-ink">{p.sub}</p>
              <p class="mt-2 text-sm leading-[1.7] text-graphite-light">{p.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="service" class="py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-5">
        <div class="grid gap-10 md:grid-cols-[0.95fr_1.05fr] md:gap-14 items-start">
          <div class="rounded-[32px] bg-sand px-7 py-8 md:px-10 md:py-12 border border-sand-dark">
            <p class="text-graphite text-xs tracking-[0.32em] mb-4 uppercase">Service</p>
            <h2 class="font-serif text-3xl md:text-5xl font-bold text-ink leading-[1.14] mb-5">
              早いだけでも、<br />高いだけでもない。<br />頼みやすさまで整えています。
            </h2>
            <p class="text-graphite-light text-base leading-[1.95]">
              徳丸商会の出張買取は、価格・速度・安心感のバランスを重視したサービスです。
              はじめて依頼する方でも「何が起きるか」が分かるように、対応の流れを明確にしています。
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            {serviceCards.map((s) => (
              <div class="rounded-[28px] border border-sand-dark bg-white px-6 py-7 shadow-[0_18px_40px_rgba(18,24,30,0.05)]">
                <div class="flex items-center gap-4 mb-4">
                  <span class="flex h-12 w-12 items-center justify-center rounded-full bg-ink text-brass font-serif text-xl">
                    {s.n}
                  </span>
                  <h3 class="text-ink font-bold text-lg leading-snug">{s.title}</h3>
                </div>
                <p class="text-graphite-light text-sm md:text-base leading-[1.85]">{s.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="items" class="py-20 md:py-32 bg-[linear-gradient(180deg,#171d26_0%,#10151c_100%)] text-white">
      <div class="max-w-7xl mx-auto px-5">
        <div class="md:flex md:items-end md:justify-between gap-10 mb-10 md:mb-14">
          <div>
            <p class="text-brass-light text-xs tracking-[0.32em] mb-4 uppercase">Purchase Items</p>
            <h2 class="font-serif text-3xl md:text-5xl font-bold leading-[1.14]">
              高価買取に対応する、<br />主なアイテム
            </h2>
          </div>
          <p class="text-white/62 text-base leading-[1.85] max-w-xl">
            家電からブランド品・貴金属まで幅広く対応。画像で見せつつ、項目が細かく見えすぎないよう整理しています。
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
          {buyItems.map((item) => (
            <div class="group rounded-[26px] border border-white/8 bg-white/[0.04] p-4 md:p-5 shadow-[0_16px_35px_rgba(0,0,0,0.18)] hover:-translate-y-1 transition-transform duration-300">
              <div class="aspect-square rounded-[22px] bg-[linear-gradient(180deg,#f7f1e6_0%,#f1e8db_100%)] p-3 overflow-hidden">
                <div class="relative flex h-full w-full items-center justify-center rounded-[18px] border border-sand-dark/80 bg-white shadow-[inset_0_1px_0_rgba(255,255,255,0.75)]">
                  <div class="pointer-events-none absolute inset-5 rounded-full bg-[radial-gradient(circle,rgba(195,154,81,0.12),transparent_68%)]"></div>
                  <img
                    src={item.img}
                    alt={`${item.name}の買取`}
                    width="200"
                    height="200"
                    class="relative z-10 h-full w-full object-contain p-5 drop-shadow-[0_18px_24px_rgba(0,0,0,0.12)]"
                    loading="lazy"
                  />
                </div>
              </div>
              <div class="mt-4 flex items-center justify-between gap-3">
                <p class="text-white font-bold text-sm md:text-base leading-snug">{item.name}</p>
                <span class="text-[11px] text-brass uppercase tracking-[0.16em]">Buy</span>
              </div>
            </div>
          ))}
        </div>

        <p class="text-white/48 text-sm mt-6">
          ゲーム機・香水・高級家具ほか、上記以外のお品物もお気軽にご相談ください。
        </p>
      </div>
    </section>

    <section id="results" class="py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-5">
        <div class="md:flex md:items-end md:justify-between gap-10 mb-10 md:mb-14">
          <div>
            <p class="text-brass-dark text-xs tracking-[0.32em] mb-4 uppercase">Track Record</p>
            <h2 class="font-serif text-3xl md:text-5xl font-bold text-ink leading-[1.14]">
              買取実績も、<br />見た瞬間に分かるように。
            </h2>
          </div>
          <p class="text-graphite-light text-base leading-[1.85] max-w-xl">
            商品名・状態のイメージ・価格帯の3点が一目で伝わるように、カードの情報量を整理しました。
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 md:gap-6">
          {results.map((r) => (
            <div class="rounded-[28px] border border-sand-dark bg-white p-4 md:p-5 shadow-[0_18px_40px_rgba(18,24,30,0.05)]">
              <div class="aspect-[4/3] overflow-hidden rounded-[22px] bg-sand mb-5">
                <img
                  src={r.image}
                  alt={`${r.name}の買取実績`}
                  width="400"
                  height="300"
                  class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                  loading="lazy"
                />
              </div>
              <p class="text-[11px] tracking-[0.18em] uppercase text-graphite-light mb-2">{r.detail}</p>
              <p class="text-ink font-bold text-lg">{r.name}</p>
              <div class="mt-4 inline-flex items-end gap-1 rounded-full bg-sand px-4 py-2">
                <span class="font-serif text-brass-dark text-3xl leading-none">¥{r.price}</span>
                <span class="text-sm text-graphite-light mb-0.5">〜</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-32 bg-sand">
      <div class="max-w-7xl mx-auto px-5">
        <div class="md:flex md:items-end md:justify-between gap-10 mb-10 md:mb-14">
          <div>
            <p class="text-graphite text-xs tracking-[0.32em] mb-4 uppercase">Before &amp; After</p>
            <h2 class="font-serif text-3xl md:text-5xl font-bold text-ink leading-[1.14]">
              片付かない部屋も、<br />搬出までまるごと対応。
            </h2>
          </div>
          <p class="text-graphite-light text-base leading-[1.85] max-w-xl">
            「運べない」「まとめて見てほしい」という相談に強いのが出張買取の価値です。写真でも変化が直感的に分かる見せ方にしています。
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-5 md:gap-7">
