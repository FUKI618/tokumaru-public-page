---
import SpecializedLP from "../layouts/SpecializedLP.astro";
import CTASection from "../components/CTASection.astro";
---

<SpecializedLP
  title="名古屋のエアコン取外し・出張買取｜徳丸商会"
  description="名古屋市でエアコンの取外し・出張買取なら徳丸商会。取外し工事込みで買取。出張費0円・その場で現金払い。052-990-3968"
  slug="aircon"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy via-navy-light to-navy text-white py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-5 text-center">
      <p class="text-gold text-xs md:text-sm font-bold mb-3">取外し工事込みの出張買取</p>
      <h1 class="text-2xl md:text-5xl font-black leading-tight mb-4">
        エアコンを<br />
        <span class="text-gold">取外し込みで買取</span>
      </h1>
      <p class="text-sm md:text-lg text-white/80 mb-6 leading-relaxed">
        面倒な取外し工事もスタッフが対応。取外し費用は買取額から差し引きません。
      </p>
      <div class="flex justify-center">
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-black text-gold">¥21,000<span class="text-sm">〜</span></p>
          <p class="text-[10px] md:text-xs text-white/60">エアコン買取実績</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 対応内容 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="text-xl md:text-3xl font-bold text-center text-navy mb-8">エアコン買取の対応内容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { title: "壁掛けエアコン", text: "一般的なルームエアコン。取外し・買取に対応。" },
          { title: "マルチエアコン", text: "1台の室外機で複数台を動かすタイプも対応可能。" },
          { title: "業務用エアコン", text: "店舗・オフィスの天井埋め込み型もご相談ください。" },
          { title: "取外し工事", text: "配管の取外し・穴埋めまで丁寧に対応します。" },
        ].map((item) => (
          <div class="bg-cream rounded-xl p-5">
            <h3 class="font-bold text-navy mb-1">{item.title}</h3>
            <p class="text-warm-gray text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- シーズン情報 -->
  <section class="py-12 md:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="text-xl md:text-3xl font-bold text-center text-navy mb-8">エアコン買取のベストタイミング</h2>
      <div class="bg-white rounded-xl p-6 border border-cream-dark text-left">
        <p class="text-warm-gray text-sm leading-[1.9]">
          エアコンは<strong class="text-navy">春〜初夏（3月〜6月）</strong>が最も高く売れる時期です。需要が高まる夏前に中古エアコンの流通が増えるため、この時期は買取価格が上がります。逆に冬場は需要が落ちるため、売却をお考えなら早めのご相談がおすすめです。
        </p>
      </div>
    </div>
  </section>

  <CTASection id="cta-mid" variant="mid" />
</SpecializedLP>
