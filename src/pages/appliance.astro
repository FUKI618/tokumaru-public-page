---
import SpecializedLP from "../layouts/SpecializedLP.astro";
import CTASection from "../components/CTASection.astro";
import { homePath, pagePath } from "../lib/site";

const faqs = [
  { q: "製造から何年以内なら買取できますか？", a: "基本は製造5年以内が高価買取の対象です。6年以上でも状態やメーカーによっては買取可能ですので、まずはご相談ください。" },
  { q: "動かない冷蔵庫や洗濯機も買い取れますか？", a: "故障品の買取は難しい場合がありますが、処分・回収には対応可能です。まとめてご依頼いただければ費用を抑えられます。" },
  { q: "説明書や保証書がなくても大丈夫ですか？", a: "付属品がなくても買取可能です。ただし保証書・リモコン・付属品が揃っていれば査定額がアップします。" },
  { q: "冷蔵庫と洗濯機をまとめて売ると高くなりますか？", a: "はい、まとめ売りで査定額を上乗せしております。引越し時にまとめてご依頼いただくケースが多いです。" },
  { q: "搬出の際に壁や床に傷がつきませんか？", a: "養生シートで床・壁・ドア枠を保護した上で搬出します。万が一の損傷にも対応いたします。" },
  { q: "どのメーカーが高く売れますか？", a: "パナソニック・日立・三菱・東芝・シャープの国内主要メーカーは高価買取の傾向があります。海外メーカーも対応可能です。" },
];

const stats = [
  { label: "最短訪問", value: "30分", text: "名古屋市内なら当日対応も可能" },
  { label: "出張費", value: "0円", text: "査定のみでも費用はかかりません" },
  { label: "対応品目", value: "大型OK", text: "冷蔵庫もドラム式も搬出まで対応" },
];

const pricingRows = [
  ["1年落ち", "20,000〜50,000円", "10,000〜30,000円"],
  ["2年落ち", "15,000〜35,000円", "7,000〜20,000円"],
  ["3年落ち", "5,000〜25,000円", "3,000〜15,000円"],
  ["5年落ち", "〜10,000円", "〜5,000円"],
];

const tips = [
  { title: "製造5年以内で売る", text: "冷蔵庫や洗濯機は年式で査定が大きく変わります。迷っているなら早めの相談が有利です。" },
  { title: "付属品をまとめる", text: "給水ホース、排水ホース、説明書、保証書、棚板があると査定が安定します。" },
  { title: "庫内と外装を軽く清掃", text: "汚れや臭いの印象が改善されるだけで、減額を避けやすくなります。" },
  { title: "複数台を一緒に依頼", text: "引越しや買い替え時は、冷蔵庫と洗濯機を同時査定にした方が金額がまとまりやすいです。" },
];

const makers = ["パナソニック", "日立", "三菱電機", "東芝", "シャープ", "ダイキン", "アイリスオーヤマ", "ハイアール", "アクア"];

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const pageUrl = new URL(pagePath("appliance"), siteUrl).toString();
const homeUrl = new URL(homePath, siteUrl).toString();

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: homeUrl },
      { "@type": "ListItem", position: 2, name: "冷蔵庫・洗濯機の出張買取", item: pageUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "冷蔵庫・洗濯機の出張買取",
    serviceType: "家電出張買取",
    areaServed: "名古屋市・近郊",
    provider: {
      "@type": "LocalBusiness",
      name: "徳丸商会",
      telephone: "052-990-3968",
      url: homeUrl,
    },
    url: pageUrl,
    description: "冷蔵庫・洗濯機の出張査定から搬出、現金買取まで対応する徳丸商会のサービスページです。",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.a,
      },
    })),
  },
];
---

<SpecializedLP
  title="名古屋の冷蔵庫・洗濯機 出張買取｜徳丸商会"
  description="名古屋市で冷蔵庫・洗濯機の出張買取なら徳丸商会。製造5年以内は高価買取。大型家電の搬出もお任せ。出張費0円・その場で現金払い。052-990-3968"
  slug="appliance"
  extraJsonLd={structuredData}
>
  <section class="relative overflow-hidden bg-[linear-gradient(180deg,#131920_0%,#161e27_55%,#202a35_100%)] text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(195,154,81,0.22),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.06),transparent_22%)]"></div>
    <div class="relative max-w-7xl mx-auto px-5 py-14 md:py-20">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] items-end">
        <div>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="rounded-full border border-brass/35 bg-brass/12 px-3 py-1 text-[11px] font-bold tracking-[0.18em] text-brass uppercase">Appliance Buyback</span>
            <span class="rounded-full border border-white/10 bg-white/6 px-3 py-1 text-[11px] text-white/72">冷蔵庫・洗濯機の搬出まで対応</span>
          </div>
          <h1 class="font-serif text-[2.35rem] leading-[1.08] md:text-[4.3rem] mb-6">
            冷蔵庫・洗濯機は、<br />
            <span class="text-brass">持ち出さずに売る</span>のが一番早い。
          </h1>
          <p class="max-w-2xl text-base md:text-lg leading-[1.9] text-white/76 mb-8">
            名古屋で大型家電を売るなら、搬出まで任せられる出張買取の方が合理的です。
            徳丸商会なら年式・メーカー・状態を見てその場で査定し、金額にご納得いただければ現金でお支払いします。
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-8">
            {stats.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.05] px-5 py-4 backdrop-blur-sm">
                <p class="text-white/45 text-[11px] tracking-[0.22em] uppercase mb-2">{item.label}</p>
                <p class="font-serif text-3xl leading-none text-white mb-2">{item.value}</p>
                <p class="text-sm leading-[1.7] text-white/68">{item.text}</p>
              </div>
            ))}
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="#cta-mid" class="inline-flex items-center justify-center rounded-full bg-brass px-7 py-4 text-sm md:text-base font-bold text-ink shadow-[0_18px_40px_rgba(195,154,81,0.28)] hover:bg-brass-light transition-colors">無料査定を依頼する</a>
            <a href="tel:052-990-3968" class="inline-flex items-center justify-center rounded-full border border-white/14 bg-white/4 px-7 py-4 text-sm md:text-base font-bold text-white hover:border-white/28 hover:bg-white/7 transition-all">電話で相談する 052-990-3968</a>
          </div>
        </div>

        <div class="rounded-[30px] border border-white/10 bg-white/[0.05] p-6 md:p-7 shadow-[0_28px_70px_rgba(0,0,0,0.24)] backdrop-blur-sm">
          <p class="text-brass text-[11px] tracking-[0.22em] uppercase mb-3">Quick Answer</p>
          <h2 class="font-serif text-2xl md:text-[2rem] leading-tight mb-5">このページで先に結論だけ。</h2>
          <div class="space-y-3">
            {[
              "製造5年以内の国内メーカーは査定がまとまりやすいです。",
              "ドラム式洗濯機や大型冷蔵庫も、搬出作業込みで対応できます。",
              "説明書がなくても査定可能。付属品が残っていれば上積みしやすくなります。",
            ].map((point) => (
              <div class="rounded-2xl border border-white/8 bg-white/[0.04] px-4 py-4 text-sm leading-[1.8] text-white/76">{point}</div>
            ))}
          </div>
          <div class="mt-5 grid grid-cols-2 gap-3">
            <div class="rounded-2xl bg-sand px-4 py-4 text-ink">
              <p class="text-[11px] tracking-[0.18em] uppercase text-graphite-light mb-1">実績例</p>
              <p class="font-bold text-base">冷蔵庫 39,000円〜</p>
            </div>
            <div class="rounded-2xl bg-brass px-4 py-4 text-ink">
              <p class="text-[11px] tracking-[0.18em] uppercase text-ink/80 mb-1">実績例</p>
              <p class="font-bold text-base">洗濯機 24,500円〜</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-10 -mt-7 md:-mt-9">
    <div class="max-w-7xl mx-auto px-5">
      <div class="grid gap-3 md:grid-cols-3">
        {[
          { title: "買い替え前に売れる", text: "新しい家電の搬入前に、不要な家電だけ先に整理できます。" },
          { title: "重い家電を動かさなくていい", text: "階段や狭い通路があっても、養生しながらスタッフが搬出します。" },
          { title: "処分と比較しやすい", text: "値段が付くか、回収になるかを現地で明確に判断できます。" },
        ].map((item) => (
          <div class="rounded-[26px] border border-sand-dark bg-white px-6 py-6 shadow-[0_22px_45px_rgba(18,24,30,0.08)]">
            <p class="text-ink font-bold text-lg mb-2">{item.title}</p>
            <p class="text-sm leading-[1.8] text-graphite-light">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-5">
      <div class="grid gap-10 lg:grid-cols-[0.88fr_1.12fr] items-start">
        <div class="rounded-[32px] border border-sand-dark bg-sand px-7 py-8 md:px-10 md:py-10">
          <p class="text-graphite text-xs tracking-[0.32em] uppercase mb-4">Price Range</p>
          <h2 class="font-serif text-3xl md:text-5xl text-ink leading-[1.14] mb-5">
            年式で、<br />家電の価値は大きく変わります。
          </h2>
          <p class="text-base leading-[1.9] text-graphite-light">
            家電は新しいほど査定が安定します。特に冷蔵庫・洗濯機は製造から5年以内が高価買取の中心です。
            まずは年式を確認しておくと、概算査定が出しやすくなります。
          </p>
        </div>

        <div class="rounded-[30px] border border-sand-dark bg-white p-4 md:p-6 shadow-[0_20px_50px_rgba(18,24,30,0.06)]">
          <div class="overflow-x-auto">
            <table class="w-full min-w-[560px] text-sm">
              <thead>
                <tr class="border-b border-sand-dark">
                  <th class="px-4 py-4 text-left font-bold text-ink">製造年数</th>
                  <th class="px-4 py-4 text-right font-bold text-ink">冷蔵庫</th>
                  <th class="px-4 py-4 text-right font-bold text-ink">洗濯機</th>
                </tr>
              </thead>
              <tbody>
                {pricingRows.map(([year, fridge, wash], index) => (
                  <tr class={index % 2 === 0 ? "bg-sand-light" : ""}>
                    <td class="px-4 py-4 font-bold text-ink">{year}</td>
                    <td class="px-4 py-4 text-right font-bold text-brass-dark">{fridge}</td>
                    <td class="px-4 py-4 text-right font-bold text-brass-dark">{wash}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-xs leading-[1.8] text-graphite-light">※メーカー、状態、容量、付属品の有無によって変動します。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[linear-gradient(180deg,#171d26_0%,#10151c_100%)] text-white">
    <div class="max-w-7xl mx-auto px-5">
      <div class="md:flex md:items-end md:justify-between gap-10 mb-10 md:mb-14">
        <div>
          <p class="text-brass-light text-xs tracking-[0.32em] uppercase mb-4">Selling Tips</p>
          <h2 class="font-serif text-3xl md:text-5xl leading-[1.14]">家電を高く売るために、<br />現場で見ている4つのポイント</h2>
        </div>
        <p class="max-w-xl text-sm md:text-base leading-[1.9] text-white/70">
          プロっぽさは装飾ではなく、判断材料を先に出しているかで決まります。このページもその方針に合わせています。
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {tips.map((item, index) => (
          <div class="rounded-[28px] border border-white/8 bg-white/[0.05] px-6 py-7 shadow-[0_18px_40px_rgba(0,0,0,0.16)]">
            <p class="text-brass text-sm font-bold mb-4">0{index + 1}</p>
            <h3 class="text-lg font-bold leading-snug mb-3">{item.title}</h3>
            <p class="text-sm leading-[1.85] text-white/68">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-5">
      <div class="rounded-[32px] border border-sand-dark bg-white px-6 py-8 md:px-10 md:py-10 shadow-[0_18px_40px_rgba(18,24,30,0.05)]">
        <p class="text-graphite text-xs tracking-[0.32em] uppercase mb-4">Supported Makers</p>
        <h2 class="font-serif text-3xl md:text-4xl text-ink leading-[1.2] mb-5">査定が集まりやすい主要メーカーに対応</h2>
        <p class="text-base leading-[1.9] text-graphite-light mb-8">
          国内主要メーカーはもちろん、海外メーカーや一人暮らし向けモデルまで対応しています。
          「値段が付くかわからない」家電も、まずは写真だけでご相談ください。
        </p>
        <div class="flex flex-wrap gap-3">
          {makers.map((maker) => (
            <span class="rounded-full border border-sand-dark bg-sand-light px-4 py-2 text-sm font-bold text-ink">{maker}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection id="cta-mid" variant="mid" />

  <section class="py-20 md:py-28 bg-sand-light">
    <div class="max-w-4xl mx-auto px-5">
      <div class="text-center mb-10">
        <p class="text-graphite text-xs tracking-[0.32em] uppercase mb-4">FAQ</p>
        <h2 class="font-serif text-3xl md:text-5xl text-ink leading-[1.14]">冷蔵庫・洗濯機の買取で<br />よくある質問</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <div x-data="{ open: false }" class="rounded-[26px] border border-sand-dark bg-white shadow-[0_16px_36px_rgba(18,24,30,0.04)] overflow-hidden">
            <button x-on:click="open = !open" class="w-full flex items-start justify-between gap-4 px-5 py-5 text-left" x-bind:aria-expanded="open.toString()">
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-ink text-xs font-bold text-white">Q</span>
                <span class="text-sm md:text-base font-bold leading-[1.7] text-ink">{faq.q}</span>
              </div>
              <span class="mt-1 text-2xl leading-none text-brass" x-text="open ? '−' : '+'"></span>
            </button>
            <div x-show="open" x-transition style="display: none;" class="px-5 pb-5">
              <div class="flex items-start gap-3 border-t border-sand-dark pt-4">
                <span class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-brass text-xs font-bold text-ink">A</span>
                <p class="text-sm md:text-base leading-[1.9] text-graphite-light">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</SpecializedLP>
