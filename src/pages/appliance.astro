---
import SpecializedLP from "../layouts/SpecializedLP.astro";
import CTASection from "../components/CTASection.astro";

const faqs = [
  { q: "製造から何年以内なら買取できますか？", a: "基本は製造5年以内が高価買取の対象です。6年以上でも状態やメーカーによっては買取可能ですので、まずはご相談ください。" },
  { q: "動かない冷蔵庫や洗濯機も買い取れますか？", a: "故障品の買取は難しい場合がありますが、処分・回収には対応可能です。まとめてご依頼いただければ費用を抑えられます。" },
  { q: "説明書や保証書がなくても大丈夫ですか？", a: "付属品がなくても買取可能です。ただし保証書・リモコン・付属品が揃っていれば査定額がアップします。" },
  { q: "冷蔵庫と洗濯機をまとめて売ると高くなりますか？", a: "はい、まとめ売りで査定額を上乗せしております。引越し時にまとめてご依頼いただくケースが多いです。" },
  { q: "搬出の際に壁や床に傷がつきませんか？", a: "養生シートで床・壁・ドア枠を保護した上で搬出します。万が一の損傷にも対応いたします。" },
  { q: "どのメーカーが高く売れますか？", a: "パナソニック・日立・三菱・東芝・シャープの国内主要メーカーは高価買取の傾向があります。海外メーカーも対応可能です。" },
];
---

<SpecializedLP
  title="名古屋の冷蔵庫・洗濯機 出張買取｜徳丸商会"
  description="名古屋市で冷蔵庫・洗濯機の出張買取なら徳丸商会。製造5年以内は高価買取。大型家電の搬出もお任せ。出張費0円・その場で現金払い。052-990-3968"
  slug="appliance"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy via-navy-light to-navy text-white py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-5 text-center">
      <p class="text-gold text-xs md:text-sm font-bold mb-3">冷蔵庫・洗濯機の出張買取専門</p>
      <h1 class="text-2xl md:text-5xl font-black leading-tight mb-4">
        冷蔵庫・洗濯機を<br /><span class="text-gold">高価買取</span>いたします
      </h1>
      <p class="text-sm md:text-lg text-white/80 mb-6 leading-relaxed">
        大型家電の搬出もスタッフにお任せ。重い物を運ぶ必要はありません。
      </p>
      <div class="flex justify-center gap-6 md:gap-10">
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-black text-gold">¥39,000<span class="text-sm">〜</span></p>
          <p class="text-[10px] md:text-xs text-white/60">冷蔵庫 買取実績</p>
        </div>
        <div class="w-px bg-white/20"></div>
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-black text-gold">¥24,500<span class="text-sm">〜</span></p>
          <p class="text-[10px] md:text-xs text-white/60">洗濯機 買取実績</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 買取相場表 -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="text-xl md:text-3xl font-bold text-center text-navy mb-8">製造年数別の買取相場</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-navy text-white">
              <th class="px-4 py-3 text-left rounded-tl-lg">製造年数</th>
              <th class="px-4 py-3 text-right">冷蔵庫（大型）</th>
              <th class="px-4 py-3 text-right rounded-tr-lg">洗濯機</th>
            </tr>
          </thead>
          <tbody>
            {[
              ["1年落ち", "20,000〜50,000円", "10,000〜30,000円"],
              ["2年落ち", "15,000〜35,000円", "7,000〜20,000円"],
              ["3年落ち", "5,000〜25,000円", "3,000〜15,000円"],
              ["5年落ち", "〜10,000円", "〜5,000円"],
            ].map(([year, fridge, wash], i) => (
              <tr class={i % 2 === 0 ? "bg-cream" : "bg-white"}>
                <td class="px-4 py-3 font-bold text-navy">{year}</td>
                <td class="px-4 py-3 text-right text-cta font-bold">{fridge}</td>
                <td class="px-4 py-3 text-right text-cta font-bold">{wash}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-warm-gray-light text-xs mt-4 text-center">※メーカー・状態・付属品の有無により変動します</p>
    </div>
  </section>

  <!-- 高く売るコツ -->
  <section class="py-12 md:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="text-xl md:text-3xl font-bold text-center text-navy mb-8">家電を高く売る4つのコツ</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { title: "製造5年以内に売る", text: "家電は1年ごとに20〜30%値下がり。早ければ早いほど高額に。" },
          { title: "付属品を揃える", text: "リモコン・説明書・保証書があると査定額がアップします。" },
          { title: "きれいに掃除する", text: "外観や内部を掃除するだけで印象が変わり、査定に好影響。" },
          { title: "まとめ売りする", text: "冷蔵庫+洗濯機+エアコンなど、複数台で査定額を上乗せ。" },
        ].map((item) => (
          <div class="bg-white rounded-xl p-5 border border-cream-dark">
            <h3 class="font-bold text-navy mb-1 text-sm md:text-base">{item.title}</h3>
            <p class="text-warm-gray text-xs md:text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 対応メーカー -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="text-xl md:text-3xl font-bold text-center text-navy mb-8">主要メーカーすべて対応</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {["パナソニック", "日立", "三菱電機", "東芝", "シャープ", "ダイキン", "アイリスオーヤマ", "ハイアール", "その他海外メーカー"].map((maker) => (
          <span class="bg-cream text-navy text-xs md:text-sm font-bold px-4 py-2 rounded-lg">{maker}</span>
        ))}
      </div>
    </div>
  </section>

  <CTASection id="cta-mid" variant="mid" />

  <!-- FAQ -->
  <section class="py-12 md:py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-5">
      <h2 class="text-xl md:text-3xl font-bold text-center text-navy mb-8">冷蔵庫・洗濯機買取のよくある質問</h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <div x-data="{ open: false }" class="bg-white rounded-xl border border-cream-dark overflow-hidden">
            <button x-on:click="open = !open" class="w-full flex items-center justify-between gap-3 p-4 text-left hover:bg-cream/50 transition-colors" x-bind:aria-expanded="open.toString()">
              <div class="flex items-start gap-2">
                <span class="flex-shrink-0 w-6 h-6 bg-navy text-white text-xs font-bold rounded-full flex items-center justify-center mt-0.5">Q</span>
                <span class="font-bold text-navy text-sm">{faq.q}</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-warm-gray flex-shrink-0 transition-transform duration-300" x-bind:class="open && 'rotate-180'" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div x-show="open" x-transition class="px-4 pb-4" style="display: none;">
              <div class="flex items-start gap-2 pt-2 border-t border-cream-dark">
                <span class="flex-shrink-0 w-6 h-6 bg-gold text-white text-xs font-bold rounded-full flex items-center justify-center mt-0.5">A</span>
                <p class="text-warm-gray text-xs md:text-sm leading-relaxed">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</SpecializedLP>
