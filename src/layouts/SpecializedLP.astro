---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import SideNav from "../components/SideNav.astro";
import CTASection from "../components/CTASection.astro";
import Area from "../components/Area.astro";
import Footer from "../components/Footer.astro";
import FloatingCTA from "../components/FloatingCTA.astro";

interface Props {
  title: string;
  description: string;
  slug: string;
  extraJsonLd?: Record<string, unknown>[];
}

const { title, description, slug, extraJsonLd = [] } = Astro.props;
---

<Layout title={title} description={description} extraJsonLd={extraJsonLd}>
  <Header />
  <main class="pt-16 md:pt-[72px]">
    <slot />
    <SideNav currentSlug={slug} />
    <Area />
    <CTASection id="contact" variant="bottom" />
  </main>
  <Footer />
  <FloatingCTA />
</Layout>
